{
  "name": "@drakon-systems/multi-clawd",
  "version": "1.0.0",
  "description": "Multi-account Claude Code failover for OpenClaw — register additional Claude (Max/Pro) logins as first-class CLI backends and keep the full skills/MCP harness across every account.",
  "type": "module",
  "license": "MIT",
  "author": "Drakon Systems Ltd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Drakon-Systems-Ltd/multi-clawd.git"
  },
  "keywords": [
    "openclaw",
    "claude",
    "claude-code",
    "cli-backend",
    "failover",
    "multi-account",
    "anthropic",
    "plugin"
  ],
  "openclaw": {
    "build": {
      "openclawVersion": "2026.6.11"
    },
    "extensions": [
      "./src/index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    }
  },
  "main": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "scripts",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build",
    "doctor": "node scripts/doctor.mjs",
    "setup": "node scripts/setup.mjs"
  },
  "peerDependencies": {
    "openclaw": ">=2026.6"
  },
  "devDependencies": {
    "openclaw": "2026.7.1",
    "typescript": "^5.9.0",
    "vitest": "^4.1.10"
  }
}
